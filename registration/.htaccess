Options -Indexes
RewriteEngine On

# ── Remove .php extension ─────────────────────────────────────
# Redirect existing .php URLs to their clean version (avoid duplicate content)
RewriteCond %{THE_REQUEST} /([^.]+)\.php [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# Internally serve the .php file when the clean URL is requested
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^/]+)/?$ $1.php [L,NC]

# ── Security headers ──────────────────────────────────────────
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Block sensitive files from direct access ──────────────────
<FilesMatch "^(db|mailer|mail_config|logger|confirmation_pdf)\.php$">
    Deny from all
</FilesMatch>

# ── Block dot files ───────────────────────────────────────────
<FilesMatch "^\.">
    Deny from all
</FilesMatch>

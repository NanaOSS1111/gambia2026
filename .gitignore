# Dependencies (rebuilt via composer install)
/vendor/

# User-uploaded files (live data, not source code)
/uploads/*
!/uploads/.gitkeep

# Sensitive config – copy *.example.php → *.php and fill in credentials
/db.php
/mail_config.php

# Runtime / server-generated files
error_log
*.log
/logs/

# Environment overrides
.env
.env.*

# OS / editor artefacts
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
